# ============================================
# Backend - Biến môi trường mẫu
# Copy thành .env và điền giá trị thực
# ============================================

# MongoDB (dùng chung cho auth, checkin, ...)
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# JWT (auth-service, checkin-service, payment-service)
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ============================================
# API GATEWAY – URL các service (khi deploy production)
# Trên Ticket/Railway: set từng biến cho service api-gateway
# ============================================
AUTH_SERVICE_URL=http://localhost:4001
LAYOUT_SERVICE_URL=http://localhost:4002
BOOKING_SERVICE_URL=http://localhost:4003
PAYMENT_SERVICE_URL=http://localhost:4004
CHECKIN_SERVICE_URL=http://localhost:4005

# Gateway & app
PORT=4000
FRONTEND_URL=http://localhost:3000

# Checkin service (khi chạy riêng)
CHECKIN_SERVICE_PORT=4005
